# ============================================================
# LAPIDARE · Variáveis de ambiente
# ============================================================
# Copie este arquivo para .env e preencha com os dados do
# seu projeto Supabase.
#
# Como pegar cada valor:
#   1. VITE_SUPABASE_URL:
#      Supabase → Project Settings → General → copie Project ID
#      e monte a URL como: https://<PROJECT_ID>.supabase.co
#
#   2. VITE_SUPABASE_ANON_KEY:
#      Supabase → Project Settings → API Keys → copie a
#      "Publishable key" (começa com sb_publishable_...)
#
#      Obs: se você estiver em um projeto antigo, pode aparecer
#      como "anon public key" começando com eyJ... — também funciona.
#
# No Netlify, configure em: Site settings → Environment variables.
# ============================================================

VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
